<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<Pane fx:id="menuPane"
      maxHeight="-Infinity"
      maxWidth="-Infinity"
      minHeight="-Infinity"
      minWidth="-Infinity"
      prefHeight="540.0"
      prefWidth="960.0"
      snapToPixel="false"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fabianrodas.javadash.MenuController">

    <children>

        <!-- El fondo se crea desde MenuController -->
        <Pane fx:id="backgroundLayer"
              prefHeight="540.0"
              prefWidth="960.0"
              mouseTransparent="true" />

        <!-- El suelo se crea desde MenuController -->
        <Pane fx:id="groundLayer"
              layoutY="400.0"
              prefHeight="150.0"
              prefWidth="960.0"
              mouseTransparent="true" />

        <ImageView fx:id="title"
                   fitHeight="119.0"
                   fitWidth="513.0"
                   layoutX="224.0"
                   layoutY="37.0"
                   pickOnBounds="true"
                   preserveRatio="true">
            <image>
                <Image url="@../images/title.png" />
            </image>
        </ImageView>

        <HBox fx:id="menuHbox1"
              alignment="CENTER"
              layoutX="204.0"
              layoutY="170.0"
              prefHeight="186.0"
              prefWidth="554.0"
              spacing="40.0">
            <children>

                <ImageView fx:id="garageBtn"
                           fitHeight="125.0"
                           fitWidth="250.0"
                           onMouseClicked="#goToGarage"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../buttons/GJ_garageBtn_001.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="playBtn"
                           fitHeight="175.0"
                           fitWidth="250.0"
                           onMouseClicked="#goToMainLevels"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../buttons/GJ_playBtn_001.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="creatorBtn"
                           fitHeight="125.0"
                           fitWidth="250.0"
                           onMouseClicked="#goToCreator"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../buttons/GJ_creatorBtn_001.png" />
                    </image>
                </ImageView>

            </children>
        </HBox>

        <HBox fx:id="menuHbox2"
              alignment="CENTER"
              layoutX="295.0"
              layoutY="418.0"
              prefHeight="108.0"
              prefWidth="372.0"
              spacing="15.0">
            <children>

                <ImageView fx:id="optionsBtn"
                           fitHeight="90.0"
                           fitWidth="250.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../buttons/GJ_optionsBtn_001.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="statsBtn"
                           fitHeight="90.0"
                           fitWidth="250.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../buttons/GJ_statsBtn_001.png" />
                    </image>
                </ImageView>

                <ImageView fx:id="githubBtn"
                           fitHeight="90.0"
                           fitWidth="250.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../buttons/GJ_githubBtn_001.png" />
                    </image>
                </ImageView>

            </children>
        </HBox>

        <VBox fx:id="extrasVbox"
              layoutX="14.0"
              layoutY="432.0"
              prefHeight="81.0"
              prefWidth="195.0">
            <children>

                <HBox prefHeight="45.0"
                      prefWidth="195.0"
                      spacing="5.0">
                    <children>

                        <ImageView fx:id="discordIcon"
                                   fitHeight="39.0"
                                   fitWidth="222.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">
                            <image>
                                <Image url="@../images/gj_discordIcon_001.png" />
                            </image>
                        </ImageView>

                        <ImageView fx:id="instaIcon"
                                   fitHeight="39.0"
                                   fitWidth="222.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">
                            <image>
                                <Image url="@../images/gj_instaIcon_001.png" />
                            </image>
                        </ImageView>

                        <ImageView fx:id="githubIcon"
                                   fitHeight="39.0"
                                   fitWidth="222.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">
                            <image>
                                <Image url="@../images/gj_githubIcon_001.png" />
                            </image>
                        </ImageView>

                    </children>
                </HBox>

                <ImageView fx:id="itsferh"
                           fitHeight="39.0"
                           fitWidth="222.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../images/itsferh.png" />
                    </image>
                </ImageView>

            </children>
        </VBox>

    </children>
</Pane>